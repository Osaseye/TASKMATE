rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an Admin (by checking their user document role)
    // Updated to handle cases where the user document might not exist yet
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the user owns the resource (based on userId field or doc ID)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // COLLECTION RULES
    // ============================================

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin() || isAuthenticated(); // Allow auth users to leave reviews
      allow delete: if isAdmin(); // Only admins can delete users
    }

    // REQUESTS COLLECTION
    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Allow updates for status changes, etc.
      allow delete: if isOwner(resource.data.customerId) || isAdmin();
    }

    // VERIFICATIONS COLLECTION
    match /verifications/{verificationId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // SETTINGS COLLECTION (Platform Config)
    match /settings/{settingId} {
      allow read: if isAuthenticated(); // Everyone needs to read settings (e.g. commission rate)
      allow write: if isAdmin(); // Only admins change settings
    }

    // SUPPORT TICKETS
    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
